{
  "name": "vaultlock-contract",
  "version": "1.0.0",
  "description": "A time-locked ETH vault smart contract built with Hardhat",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.js --network hardhat",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "ignition:sepolia": "hardhat ignition deploy ./ignition/modules/VaultLock.js --network sepolia",
    "verify": "hardhat verify --network sepolia",
    "node": "hardhat node",
    "clean": "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0",
    "dotenv": "^16.4.5"
  },
  "keywords": ["solidity", "hardhat", "ethereum", "smart-contract", "vault"],
  "author": "Ayeni (ab)",
  "license": "MIT"
}
